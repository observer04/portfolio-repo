{
  "platform": {
    "apiRuntime": "node:18",
    "applicationBuild": {
      "outputLocation": "out",
      "buildCommand": "npm run build"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "routes": [
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "public, max-age=604800"
      }
    }
  ]
}